{
  "name": "secondary-explorer",
  "displayName": "Secondary Explorer",
  "description": "Adds a secondary explorer view to manage files and folders outside the default workspace explorer.",
  "version": "14.0.1",
  "icon": "images/logo.png",
  "publisher": "Thinker",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/R35007/secondary-explorer-vscode-extension"
  },
  "author": {
    "name": "Sivaraman",
    "email": "sendmsg2siva@gmail.com"
  },
  "keywords": [
    "vscode",
    "explorer",
    "bookmark-explorer",
    "file",
    "folder",
    "notes",
    "side-notes",
    "file-system",
    "file-management",
    "file-explorer",
    "file-browser",
    "file-tree",
    "file-viewer",
    "file-organizer",
    "file-navigator",
    "file-operations",
    "secondary-explorer"
  ],
  "engines": {
    "vscode": "^1.109.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "secondary-explorer.openFile",
        "title": "Open File",
        "icon": "$(eye)"
      },
      {
        "command": "secondary-explorer.openToTheSide",
        "title": "Open to the Side",
        "icon": "$(eye)"
      },
      {
        "command": "secondary-explorer.revealInFileExplorer",
        "title": "Reveal in File Explorer",
        "icon": "$(file-directory)"
      },
      {
        "command": "secondary-explorer.revealInExplorerView",
        "title": "Reveal in Explorer View",
        "icon": "$(file-directory)"
      },
      {
        "command": "secondary-explorer.revealInSecondaryExplorer",
        "title": "Reveal in Secondary Explorer View",
        "icon": "$(file-directory)"
      },
      {
        "command": "secondary-explorer.openInTerminal",
        "title": "Open in Integrated Terminal",
        "icon": "$(terminal)"
      },
      {
        "command": "secondary-explorer.openFolderInNewWindow",
        "title": "Open in New Window",
        "icon": "$(link-external)"
      },
      {
        "command": "secondary-explorer.addSelectedToWorkspace",
        "title": "Add Folder to Workspace...",
        "icon": "$(add)"
      },
      {
        "command": "secondary-explorer.createFile",
        "title": "New File...",
        "icon": "$(new-file)"
      },
      {
        "command": "secondary-explorer.createFolder",
        "title": "New Folder...",
        "icon": "$(new-folder)"
      },
      {
        "command": "secondary-explorer.cutEntry",
        "title": "Cut",
        "icon": "$(cut)"
      },
      {
        "command": "secondary-explorer.copyEntry",
        "title": "Copy",
        "icon": "$(copy)"
      },
      {
        "command": "secondary-explorer.pasteEntry",
        "title": "Paste",
        "icon": "$(paste)"
      },
      {
        "command": "secondary-explorer.copyPath",
        "title": "Copy Path",
        "icon": "$(clippy)"
      },
      {
        "command": "secondary-explorer.copyRelativePath",
        "title": "Copy Relative Path",
        "icon": "$(clippy)"
      },
      {
        "command": "secondary-explorer.copyToWorkspaceRoot",
        "title": "Copy to Workspace Root",
        "icon": "$(copy)"
      },
      {
        "command": "secondary-explorer.moveToWorkspaceRoot",
        "title": "Move to Workspace Root",
        "icon": "$(move)"
      },
      {
        "command": "secondary-explorer.renameEntry",
        "title": "Rename...",
        "icon": "$(edit)"
      },
      {
        "command": "secondary-explorer.deleteEntry",
        "title": "Delete",
        "icon": "$(trash)"
      },
      {
        "command": "secondary-explorer.assignTagToPaths",
        "title": "Assign Tag to Paths...",
        "icon": "$(edit)"
      },
      {
        "command": "secondary-explorer.editPathTags",
        "title": "Manage Path Tags...",
        "icon": "$(tag)"
      },
      {
        "command": "secondary-explorer.toggleViewMode",
        "title": "Toggle View Mode"
      },
      {
        "command": "secondary-explorer.toggleEmptyDirectories",
        "title": "Toggle Empty Directories"
      },
      {
        "command": "secondary-explorer.hidePath",
        "title": "Hide From Explorer",
        "icon": "$(eye-closed)"
      },
      {
        "command": "secondary-explorer.removePath",
        "title": "Remove From Explorer",
        "icon": "$(trash)"
      },
      {
        "command": "secondary-explorer.refresh",
        "title": "Refresh",
        "icon": "$(refresh)"
      },
      {
        "command": "secondary-explorer.addToSecondaryExplorer",
        "title": "Add to Secondary Explorer",
        "icon": "$(add)"
      },
      {
        "command": "secondary-explorer.groupByTags",
        "title": "Group By Tags",
        "icon": "$(tag)"
      },
      {
        "command": "secondary-explorer.groupByNone",
        "title": "✔ Group By Tags",
        "icon": "$(tag-remove)"
      },
      {
        "command": "secondary-explorer.viewAsList",
        "title": "View as List",
        "icon": "$(list-tree)"
      },
      {
        "command": "secondary-explorer.viewAsTree",
        "title": "✔ View as List",
        "icon": "$(list-unordered)"
      },
      {
        "command": "secondary-explorer.showEmptyDirectories",
        "title": "Show Empty Directories",
        "icon": "$(eye)"
      },
      {
        "command": "secondary-explorer.hideEmptyDirectories",
        "title": "✔ Show Empty Directories",
        "icon": "$(eye-closed)"
      },
      {
        "command": "secondary-explorer.openSettings",
        "title": "Settings",
        "icon": "$(gear)"
      }
    ],
    "configuration": {
      "type": "object",
      "title": "Secondary Explorer",
      "properties": {
        "secondaryExplorer.paths": {
          "order": 1,
          "type": "array",
          "description": "List of groups to show in Secondary Explorer. Each item can be a string path or an object with baseFolder, pattern(s), ignorepattern(s), and title.",
          "items": {
            "oneOf": [
              {
                "type": "string",
                "examples": [
                  [
                    "${workspaceFolders[0]}",
                    "${workspaceFolders[1]: Source}/src",
                    "${workspaceFolder}",
                    "${workspaceFolder: Source}/src"
                  ]
                ]
              },
              {
                "type": "object",
                "properties": {
                  "tags": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    },
                    "default": [],
                    "additionalItems": true,
                    "markdownDescription": "ags used to group multiple paths into a single folder within the tree view. Helps organize your secondary explorer paths by categorizing."
                  },
                  "basePath": {
                    "type": "string",
                    "default": "${workspaceFolder}",
                    "examples": [
                      "${workspaceFolders[0]}",
                      "${workspaceFolders[1]: Source}/src",
                      "${workspaceFolder}",
                      "${workspaceFolder: Source}/src",
                      "${userHome}",
                      "${userHome: User Home}"
                    ],
                    "markdownDescription": "Base folder path. Supports ${workspaceFolder} and ${userHome}. If omitted, uses current workspace folder."
                  },
                  "include": {
                    "oneOf": [
                      {
                        "type": "string",
                        "default": "*"
                      },
                      {
                        "type": "array",
                        "default": [
                          "*"
                        ],
                        "items": {
                          "type": "string"
                        }
                      }
                    ],
                    "examples": [
                      [
                        "*.{md,markdown,txt}"
                      ],
                      [
                        "*.png",
                        "*.jpg",
                        "*.svg"
                      ],
                      [
                        "*.test.{js,ts}",
                        "*.spec.{js,ts}"
                      ]
                    ],
                    "additionalItems": true,
                    "markdownDescription": "Glob pattern(s) to include. Examples: *.md. Defaults to *"
                  },
                  "exclude": {
                    "oneOf": [
                      {
                        "type": "string",
                        "default": "node_modules"
                      },
                      {
                        "type": "array",
                        "default": [
                          "node_modules",
                          "dist",
                          "build",
                          "out"
                        ],
                        "items": {
                          "type": "string"
                        }
                      }
                    ],
                    "examples": [
                      [
                        "node_modules",
                        "dist",
                        "build",
                        "out"
                      ]
                    ],
                    "additionalItems": true,
                    "markdownDescription": "Glob pattern(s) to ignore or exclude. Defaults to node_modules, dist, build, out"
                  },
                  "name": {
                    "type": "string",
                    "examples": [
                      "${workspaceFolderName}",
                      "${workspaceFolderBasename}"
                    ],
                    "description": "Optional name for this group. Defaults to folder name."
                  },
                  "description": {
                    "type": "string",
                    "default": "",
                    "examples": [
                      "${workspaceFolder}"
                    ],
                    "description": "Provide description of the root directory"
                  },
                  "tooltip": {
                    "type": "string",
                    "default": "",
                    "description": "Provide tooltip for the root directory"
                  },
                  "hidden": {
                    "type": "boolean",
                    "default": false,
                    "description": "Whether this group is initially hidden in the explorer."
                  },
                  "showEmptyDirectories": {
                    "type": [
                      "boolean",
                      "null"
                    ],
                    "default": null,
                    "examples": [
                      true,
                      false,
                      null
                    ],
                    "description": "Set to true to show empty directories in this group. Can be set to null to use global `#secondaryExplorer.showEmptyDirectories#` setting."
                  },
                  "sortOrderPattern": {
                    "type": [
                      "array",
                      "null"
                    ],
                    "items": {
                      "type": "string"
                    },
                    "examples": [
                      [
                        "*.instructions.md",
                        "*.prompt.md",
                        "*.agent.md",
                        "*.chatmode.md",
                        "*.md"
                      ],
                      null
                    ],
                    "default": null,
                    "description": "Optional pattern to control sorting order of items in this group. Can be set to null to use global `#secondaryExplorer.itemsSortOrderPattern#` sorting order."
                  },
                  "viewAsList": {
                    "type": [
                      "boolean",
                      "null"
                    ],
                    "default": null,
                    "examples": [
                      true,
                      false,
                      null
                    ],
                    "description": "Set to true to show items in this group as a flat list instead of a tree. Can be set to null to use global `#secondaryExplorer.viewAsList#` setting."
                  }
                },
                "examples": [
                  "${workspaceFolder}",
                  "${workspaceFolder: Source}/src",
                  "${workspaceFolders[1]}",
                  "${workspaceFolders[1]: Source}/src",
                  "${userHome}",
                  "${userHome: User Home}",
                  {
                    "basePath": "${workspaceFolder}",
                    "name": "All Workspace Files",
                    "description": "${workspaceFolder}",
                    "hidden": false,
                    "include": [
                      "**/*"
                    ],
                    "exclude": [
                      "node_modules",
                      "dist",
                      "build",
                      "out",
                      ".vscode-test"
                    ],
                    "showEmptyDirectories": false,
                    "viewAsList": false,
                    "sortOrderPattern": [
                      "*.instructions.md",
                      "*.prompt.md",
                      "*.agent.md",
                      "*.chatmode.md"
                    ],
                    "tags": [
                      "Others"
                    ]
                  },
                  {
                    "basePath": "${workspaceFolders[1]}",
                    "name": "Workspace Docs",
                    "description": "Documents",
                    "tooltip": "Shows only markdown and text files",
                    "hidden": false,
                    "include": [
                      "*.{md,markdown,txt}"
                    ],
                    "showEmptyDirectories": false,
                    "viewAsList": true,
                    "sortOrderPattern": [
                      "*.instructions.md",
                      "*.prompt.md",
                      "*.agent.md",
                      "*.chatmode.md"
                    ],
                    "tags": [
                      "Documents"
                    ]
                  },
                  {
                    "basePath": "${userHome}/mac/path/to/images",
                    "name": "Workspace Images",
                    "hidden": false,
                    "include": [
                      "**/*.{png,jpg,jpeg,gif,svg,webp,avif,bmp,tiff,ico,icns,heic,heif}"
                    ],
                    "showEmptyDirectories": true,
                    "viewAsList": false,
                    "tags": [
                      "Images"
                    ]
                  },
                  {
                    "basePath": "${workspaceFolder}",
                    "name": "Workspace Tests",
                    "hidden": false,
                    "include": [
                      "*.test.{js,ts,tsx,jsx}",
                      "*.spec.{js,ts,tsx,jsx}"
                    ],
                    "tags": [
                      "Tests"
                    ]
                  }
                ],
                "additionalProperties": false
              }
            ]
          },
          "examples": [
            [
              "${workspaceFolder}",
              "${workspaceFolder: Source}/src",
              "${workspaceFolders[1]}",
              "${workspaceFolders[1]: Source}/src",
              "${userHome}",
              "${userHome: User Home}",
              {
                "basePath": "${workspaceFolder}",
                "name": "All Workspace Files",
                "description": "${workspaceFolder}",
                "hidden": false,
                "include": [
                  "**/*"
                ],
                "exclude": [
                  "node_modules",
                  "dist",
                  "build",
                  "out",
                  ".vscode-test"
                ],
                "showEmptyDirectories": false,
                "viewAsList": false,
                "sortOrderPattern": [
                  "*.instructions.md",
                  "*.prompt.md",
                  "*.agent.md",
                  "*.chatmode.md"
                ],
                "tags": [
                  "Others"
                ]
              },
              {
                "basePath": "${workspaceFolders[1]}",
                "name": "Workspace Docs",
                "description": "Documents",
                "tooltip": "Shows only markdown and text files",
                "hidden": false,
                "include": [
                  "*.{md,markdown,txt}"
                ],
                "showEmptyDirectories": false,
                "viewAsList": true,
                "sortOrderPattern": [
                  "*.instructions.md",
                  "*.prompt.md",
                  "*.agent.md",
                  "*.chatmode.md"
                ],
                "tags": [
                  "Documents"
                ]
              },
              {
                "basePath": "${userHome}/mac/path/to/images",
                "name": "Workspace Images",
                "hidden": false,
                "include": [
                  "**/*.{png,jpg,jpeg,gif,svg,webp,avif,bmp,tiff,ico,icns,heic,heif}"
                ],
                "showEmptyDirectories": true,
                "viewAsList": false,
                "tags": [
                  "Images"
                ]
              },
              {
                "basePath": "${workspaceFolder}",
                "name": "Workspace Tests",
                "hidden": false,
                "include": [
                  "*.test.{js,ts,tsx,jsx}",
                  "*.spec.{js,ts,tsx,jsx}"
                ],
                "tags": [
                  "Tests"
                ]
              }
            ]
          ],
          "default": []
        },
        "secondaryExplorer.deleteBehavior": {
          "order": 2,
          "type": "string",
          "enum": [
            "alwaysAsk",
            "recycleBin",
            "permanent"
          ],
          "enumDescriptions": [
            "Always ask before deleting (show confirmation dialog).",
            "Move to recycle bin without asking.",
            "Permanently delete without asking."
          ],
          "default": "recycleBin",
          "description": "Controls how delete operations are handled."
        },
        "secondaryExplorer.groupByTags": {
          "order": 3,
          "type": "boolean",
          "default": false,
          "description": "Organize the root level by tags. When enabled, items are grouped into virtual folders based on their assigned tags."
        },
        "secondaryExplorer.viewAsList": {
          "order": 4,
          "type": "boolean",
          "default": false,
          "description": "Set to true to show all items in the explorer as a flat list instead of a tree. By default, items are shown in a tree structure that reflects their folder hierarchy."
        },
        "secondaryExplorer.showEmptyDirectories": {
          "order": 5,
          "type": "boolean",
          "default": false,
          "description": "Set to true to show empty directories in the explorer. By default, empty directories are hidden to reduce clutter."
        },
        "secondaryExplorer.rootPathSortOrder": {
          "order": 6,
          "type": "string",
          "enum": [
            "default",
            "filesFirst",
            "foldersFirst",
            "mixed"
          ],
          "enumDescriptions": [
            "Default sorting order (sorted by secondaryExplorer.paths order).",
            "Files are shown before folders, all sorted alphabetically.",
            "Folders are shown before files, all sorted alphabetically.",
            "Mixed sorting order (folders and files mixed based on name, sorted alphabetically)."
          ],
          "default": "default",
          "description": "Controls the sorting order of items in the explorer."
        },
        "secondaryExplorer.itemsSortOrderPattern": {
          "order": 7,
          "type": "array",
          "items": {
            "type": "string"
          },
          "additionalItems": true,
          "default": [
            "*.instructions.md",
            "*.prompt.md",
            "*.agent.md",
            "*.chatmode.md",
            "*.SKILL.md"
          ],
          "examples": [
            [
              "*.instructions.md",
              "*.prompt.md",
              "*.agent.md",
              "*.chatmode.md",
              "*.md"
            ],
            [
              "*.png",
              "*.jpg",
              "*.svg"
            ]
          ],
          "description": "Controls the sorting order of items in the explorer."
        }
      }
    },
    "viewsContainers": {
      "secondarySidebar": [
        {
          "id": "secondaryExplorer",
          "title": "Secondary Explorer",
          "icon": "images/logo.png"
        }
      ]
    },
    "views": {
      "secondaryExplorer": [
        {
          "id": "secondaryExplorerView",
          "name": "Secondary Explorer",
          "contextualTitle": "Secondary Explorer",
          "visibility": "visible",
          "icon": "$(folder)"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "secondaryExplorerView",
        "contents": "No paths configured.\n[Add Folder to Explorer](command:secondary-explorer.addToSecondaryExplorer)",
        "when": "!secondaryExplorer.paths || secondaryExplorer.paths.length == 0"
      }
    ],
    "menus": {
      "commandPalette": [
        {
          "command": "secondary-explorer.refresh",
          "when": "false"
        },
        {
          "command": "secondary-explorer.addToSecondaryExplorer",
          "when": "false"
        },
        {
          "command": "secondary-explorer.openSettings",
          "when": "false"
        },
        {
          "command": "secondary-explorer.createFile",
          "when": "false"
        },
        {
          "command": "secondary-explorer.createFolder",
          "when": "false"
        },
        {
          "command": "secondary-explorer.deleteEntry",
          "when": "false"
        },
        {
          "command": "secondary-explorer.renameEntry",
          "when": "false"
        },
        {
          "command": "secondary-explorer.openFile",
          "when": "false"
        },
        {
          "command": "secondary-explorer.openToTheSide",
          "when": "false"
        },
        {
          "command": "secondary-explorer.openFolderInNewWindow",
          "when": "false"
        },
        {
          "command": "secondary-explorer.cutEntry",
          "when": "false"
        },
        {
          "command": "secondary-explorer.copyEntry",
          "when": "false"
        },
        {
          "command": "secondary-explorer.pasteEntry",
          "when": "false"
        },
        {
          "command": "secondary-explorer.revealInFileExplorer",
          "when": "false"
        },
        {
          "command": "secondary-explorer.revealInExplorerView",
          "when": "false"
        },
        {
          "command": "secondary-explorer.revealInSecondaryExplorer",
          "when": "false"
        },
        {
          "command": "secondary-explorer.copyPath",
          "when": "false"
        },
        {
          "command": "secondary-explorer.copyRelativePath",
          "when": "false"
        },
        {
          "command": "secondary-explorer.removePath",
          "when": "false"
        },
        {
          "command": "secondary-explorer.hidePath",
          "when": "false"
        },
        {
          "command": "secondary-explorer.editPathTags",
          "when": "false"
        },
        {
          "command": "secondary-explorer.assignTagToPaths",
          "when": "false"
        },
        {
          "command": "secondary-explorer.viewAsList",
          "when": "false"
        },
        {
          "command": "secondary-explorer.viewAsTree",
          "when": "false"
        },
        {
          "command": "secondary-explorer.showEmptyDirectories",
          "when": "false"
        },
        {
          "command": "secondary-explorer.hideEmptyDirectories",
          "when": "false"
        },
        {
          "command": "secondary-explorer.copyToWorkspaceRoot",
          "when": "false"
        },
        {
          "command": "secondary-explorer.moveToWorkspaceRoot",
          "when": "false"
        },
        {
          "command": "secondary-explorer.addSelectedToWorkspace",
          "when": "false"
        }
      ],
      "explorer/context": [
        {
          "command": "secondary-explorer.revealInSecondaryExplorer",
          "group": "navigation@98"
        },
        {
          "command": "secondary-explorer.addToSecondaryExplorer",
          "group": "navigation@99"
        }
      ],
      "editor/title/context": [
        {
          "command": "secondary-explorer.addToSecondaryExplorer",
          "group": "navigation@99"
        },
        {
          "command": "secondary-explorer.revealInSecondaryExplorer",
          "group": "2_reveal@99"
        }
      ],
      "view/title": [
        {
          "command": "secondary-explorer.createFile",
          "when": "view == secondaryExplorerView",
          "group": "navigation@1"
        },
        {
          "command": "secondary-explorer.createFolder",
          "when": "view == secondaryExplorerView",
          "group": "navigation@2"
        },
        {
          "command": "secondary-explorer.refresh",
          "when": "view == secondaryExplorerView",
          "group": "navigation@4"
        },
        {
          "command": "secondary-explorer.addToSecondaryExplorer",
          "when": "view == secondaryExplorerView",
          "group": "secondaryExplorer@1"
        },
        {
          "command": "secondary-explorer.groupByTags",
          "when": "view == secondaryExplorerView && !config.secondaryExplorer.groupByTags",
          "group": "secondaryExplorer@2"
        },
        {
          "command": "secondary-explorer.groupByNone",
          "when": "view == secondaryExplorerView && config.secondaryExplorer.groupByTags",
          "group": "secondaryExplorer@3"
        },
        {
          "command": "secondary-explorer.viewAsList",
          "when": "view == secondaryExplorerView && !config.secondaryExplorer.viewAsList",
          "group": "secondaryExplorer@4"
        },
        {
          "command": "secondary-explorer.viewAsTree",
          "when": "view == secondaryExplorerView && config.secondaryExplorer.viewAsList",
          "group": "secondaryExplorer@5"
        },
        {
          "command": "secondary-explorer.showEmptyDirectories",
          "when": "view == secondaryExplorerView && !config.secondaryExplorer.showEmptyDirectories",
          "group": "secondaryExplorer@6"
        },
        {
          "command": "secondary-explorer.hideEmptyDirectories",
          "when": "view == secondaryExplorerView && config.secondaryExplorer.showEmptyDirectories",
          "group": "secondaryExplorer@7"
        },
        {
          "command": "secondary-explorer.openSettings",
          "when": "view == secondaryExplorerView",
          "group": "secondaryExplorer@8"
        }
      ],
      "view/item/context": [
        {
          "command": "secondary-explorer.openFile",
          "when": "view == secondaryExplorerView && viewItem == file",
          "group": "navigation@7"
        },
        {
          "command": "secondary-explorer.openToTheSide",
          "when": "view == secondaryExplorerView && viewItem == file",
          "group": "navigation@8"
        },
        {
          "command": "secondary-explorer.revealInFileExplorer",
          "when": "view == secondaryExplorerView && viewItem != tag",
          "group": "navigation@9"
        },
        {
          "command": "secondary-explorer.revealInExplorerView",
          "when": "view == secondaryExplorerView && viewItem != tag",
          "group": "navigation@10"
        },
        {
          "command": "secondary-explorer.openInTerminal",
          "when": "view == secondaryExplorerView && viewItem != tag",
          "group": "navigation@11"
        },
        {
          "command": "secondary-explorer.openFolderInNewWindow",
          "when": "view == secondaryExplorerView && viewItem != tag",
          "group": "navigation@10"
        },
        {
          "command": "secondary-explorer.openFolderInNewWindow",
          "when": "view == secondaryExplorerView && viewItem == root",
          "group": "inline"
        },
        {
          "command": "secondary-explorer.addSelectedToWorkspace",
          "when": "view == secondaryExplorerView && viewItem != tag",
          "group": "navigation@11"
        },
        {
          "command": "secondary-explorer.createFile",
          "when": "view == secondaryExplorerView && viewItem != tag",
          "group": "1_creation@1"
        },
        {
          "command": "secondary-explorer.createFolder",
          "when": "view == secondaryExplorerView && viewItem != tag",
          "group": "1_creation@2"
        },
        {
          "command": "secondary-explorer.cutEntry",
          "when": "view == secondaryExplorerView && (viewItem == file || viewItem == folder)",
          "group": "2_clipboard@1"
        },
        {
          "command": "secondary-explorer.copyEntry",
          "when": "view == secondaryExplorerView && viewItem != tag",
          "group": "2_clipboard@2"
        },
        {
          "command": "secondary-explorer.pasteEntry",
          "when": "view == secondaryExplorerView && viewItem != tag",
          "group": "2_clipboard@3"
        },
        {
          "command": "secondary-explorer.copyPath",
          "when": "view == secondaryExplorerView && viewItem != tag",
          "group": "3_copy@1"
        },
        {
          "command": "secondary-explorer.copyRelativePath",
          "when": "view == secondaryExplorerView && viewItem != tag",
          "group": "3_copy@2"
        },
        {
          "command": "secondary-explorer.copyToWorkspaceRoot",
          "when": "view == secondaryExplorerView && viewItem != tag",
          "group": "3_copy@3"
        },
        {
          "command": "secondary-explorer.moveToWorkspaceRoot",
          "when": "view == secondaryExplorerView && viewItem != tag",
          "group": "3_copy@4"
        },
        {
          "command": "secondary-explorer.toggleViewMode",
          "when": "view == secondaryExplorerView && viewItem == root",
          "group": "4_editing@1"
        },
        {
          "command": "secondary-explorer.toggleEmptyDirectories",
          "when": "view == secondaryExplorerView && viewItem == root",
          "group": "4_editing@2"
        },
        {
          "command": "secondary-explorer.renameEntry",
          "when": "view == secondaryExplorerView && (viewItem == file || viewItem == folder)",
          "group": "5_editing@1"
        },
        {
          "command": "secondary-explorer.deleteEntry",
          "when": "view == secondaryExplorerView && (viewItem == file || viewItem == folder)",
          "group": "5_editing@2"
        },
        {
          "command": "secondary-explorer.assignTagToPaths",
          "when": "view == secondaryExplorerView && viewItem == tag",
          "group": "inline"
        },
        {
          "command": "secondary-explorer.editPathTags",
          "when": "view == secondaryExplorerView && viewItem == root",
          "group": "5_editing@3"
        },
        {
          "command": "secondary-explorer.hidePath",
          "when": "view == secondaryExplorerView && viewItem == root",
          "group": "5_editing@6"
        },
        {
          "command": "secondary-explorer.removePath",
          "when": "view == secondaryExplorerView && viewItem == root",
          "group": "5_editing@7"
        }
      ]
    },
    "keybindings": [
      {
        "command": "secondary-explorer.createFile",
        "key": "ctrl+n",
        "when": "focusedView == secondaryExplorerView && secondaryExplorer.hasSelection"
      },
      {
        "command": "secondary-explorer.cutEntry",
        "key": "ctrl+x",
        "when": "focusedView == secondaryExplorerView && secondaryExplorer.hasSelection"
      },
      {
        "command": "secondary-explorer.copyEntry",
        "key": "ctrl+c",
        "when": "focusedView == secondaryExplorerView && secondaryExplorer.hasSelection"
      },
      {
        "command": "secondary-explorer.copyPath",
        "key": "ctrl+alt+c",
        "when": "focusedView == secondaryExplorerView && secondaryExplorer.hasSelection"
      },
      {
        "command": "secondary-explorer.pasteEntry",
        "key": "ctrl+v",
        "when": "focusedView == secondaryExplorerView && secondaryExplorer.hasSelection"
      },
      {
        "command": "secondary-explorer.renameEntry",
        "key": "f2",
        "when": "focusedView == secondaryExplorerView && secondaryExplorer.hasSelection"
      },
      {
        "command": "secondary-explorer.deleteEntry",
        "key": "delete",
        "when": "focusedView == secondaryExplorerView && secondaryExplorer.hasSelection"
      }
    ]
  },
